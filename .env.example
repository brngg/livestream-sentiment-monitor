# Copy this file to .env before running Docker Compose.
# Docker Compose reads .env for interpolation; do not commit real secrets.

# Twitch API credentials are required for live-channel verification.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Optional alternatives/IRC credentials.
TWITCH_APP_ACCESS_TOKEN=
TWITCH_IRC_NICK=
TWITCH_IRC_OAUTH_TOKEN=

# Optional convenience value for curl-based smoke tests in the docs.
TWITCH_CHANNEL=

# Host ports for local access.
DASHBOARD_PORT=8090
SENTIMENT_PORT=8091
TRANSCRIPT_PORT=8092

# Container-to-container service URLs. These defaults are for Docker Compose.
NLP_ANALYZER_URL=http://sentiment-analyzer:8091
TRANSCRIPT_INGESTOR_URL=http://transcript-ingestor:8092
NLP_ANALYZER_TIMEOUT=750ms
TRANSCRIPT_NLP_ANALYZER_TIMEOUT=15
CHAT_BUCKET_EVERY=10s
TRANSCRIPT_POLL_INTERVAL=1s
TRANSCRIPT_BUCKET_SECONDS=10
EVENT_BUS_ENABLED=true
EVENT_GATEWAY_URL=http://event-gateway:8093
ANALYSIS_SERVICE_URL=http://analysis-service:8094
ANALYSIS_SERVICE_REQUIRED=true
KAFKA_BROKERS=redpanda:9092
EVENT_GATEWAY_PUBLISH_TIMEOUT=5s
ANALYSIS_ALIGNMENT_WINDOW=10s
ANALYSIS_STORAGE_TIMEOUT=2s
ANALYSIS_MAX_BUCKETS_PER_SESSION=500
REDPANDA_EXTERNAL_PORT=19092

# Production/demo safety controls. Leave ADMIN_TOKEN empty for local dev unless
# PUBLIC_START_ENABLED=false is explicitly set.
ADMIN_TOKEN=
PUBLIC_START_ENABLED=true
MAX_ACTIVE_SESSIONS=1
SESSION_MAX_DURATION=20m
LIVE_SOURCE_ALLOWLIST=
DAILY_LIVE_START_LIMIT=0

# ML runtime caps keep Docker from saturating every host CPU core.
ML_OMP_NUM_THREADS=2
ML_MKL_NUM_THREADS=2
ML_OPENBLAS_NUM_THREADS=2
ML_NUMEXPR_NUM_THREADS=2
ML_VECLIB_MAXIMUM_THREADS=2
TOKENIZERS_PARALLELISM=false
SENTIMENT_CPUS=2.0
TRANSCRIPT_CPUS=6.0
TRANSCRIPT_OMP_NUM_THREADS=6
TRANSCRIPT_OMP_THREAD_LIMIT=6
TRANSCRIPT_OPENBLAS_NUM_THREADS=1
TRANSCRIPT_MKL_NUM_THREADS=1
TRANSCRIPT_NUMEXPR_NUM_THREADS=1
TRANSCRIPT_VECLIB_MAXIMUM_THREADS=1

# Sentiment analyzer settings.
SENTIMENT_MODEL=cardiffnlp/twitter-xlm-roberta-base-sentiment-multilingual
SENTIMENT_BATCH_SIZE=16
SENTIMENT_TRACE_LIMIT=18
SENTIMENT_MAX_MESSAGES=32
SENTIMENT_MAX_TEXT_CHARS=280
SENTIMENT_DEVICE=-1
SENTIMENT_WARMUP=true

# Transcript ingestor settings. Native C++ service uses hosted NVIDIA ASR NIM.
TRANSCRIPT_DEFAULT_CHUNK_SECONDS=1
TRANSCRIPT_ASR_PROVIDER=nvidia_streaming
TRANSCRIPT_ASR_QUEUE_MAX_DEPTH=4
TRANSCRIPT_REPAIR_ENABLED=false
CAPTION_ROLLING_WINDOW_SECONDS=10
CAPTION_ASR_INTERVAL_SECONDS=1

# Hosted NVIDIA ASR NIM paths. Set TRANSCRIPT_ASR_PROVIDER=nvidia_streaming for
# one continuous live gRPC stream. nvidia_hosted remains available for chunked
# WAV transcription. Provide NVIDIA_API_KEY in .env and never commit it.
NVIDIA_API_KEY=
NVIDIA_NIM_ASR_PYTHON=python3
NVIDIA_NIM_ASR_HELPER=/app/scripts/nvidia_asr_transcribe.py
NVIDIA_NIM_ASR_STREAMING_HELPER=/app/scripts/nvidia_live_stream_asr.py
NVIDIA_NIM_ASR_SERVER=grpc.nvcf.nvidia.com:443
NVIDIA_NIM_ASR_FUNCTION_ID=bb0837de-8c7b-481f-9ec8-ef5663e9c1fa
NVIDIA_NIM_ASR_MODEL_NAME=
NVIDIA_NIM_ASR_LANGUAGE_CODE=en-US
NVIDIA_NIM_ASR_FILE_STREAMING_CHUNK=1600

# Neon is the source of truth for replay/proof/evaluation loops.
# Copy the Postgres connection string from Neon and keep sslmode=require.
DATABASE_URL=postgresql://user:password@ep-example.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_WRITE_ENABLED=true
DATABASE_WRITE_TIMEOUT=10s
CHAT_SAMPLE_LIMIT_PER_BUCKET=10
CHAT_IDENTITY_HASH_SALT=local-dev-only-change-me
