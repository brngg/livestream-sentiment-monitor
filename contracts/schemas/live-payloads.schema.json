        "signal_windows": {
          "type": "array",
          "items": { "$ref": "#/$defs/SignalWindow" }
        },
        "signal_events": {
          "type": "array",
          "items": { "$ref": "#/$defs/SignalEvent" }
        },
        "error": { "type": "string" }
      }
    },
    "ReactionWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "session_id",
        "channel_id",
        "source",
        "window_start",
        "window_end",
        "message_count",
        "unique_chatters",
        "messages_per_minute",
        "velocity_score",
        "hype_score",
        "intensity_score",
        "confusion_score",
        "frustration_score",
        "valence",
        "reaction_type",
        "target_type",
        "confidence",
        "evidence_ids",
        "evidence_messages"
      ],
      "properties": {
        "type": { "const": "reaction_window" },
        "session_id": { "type": "string" },
        "channel_id": { "type": "string" },
        "source": { "type": "string" },
        "provisional": { "type": "boolean" },
        "window_start": { "$ref": "#/$defs/Timestamp" },
        "window_end": { "$ref": "#/$defs/Timestamp" },
        "message_count": { "type": "integer", "minimum": 0 },
        "unique_chatters": { "type": "integer", "minimum": 0 },
        "messages_per_minute": { "type": "number", "minimum": 0 },
        "velocity_score": { "$ref": "#/$defs/Confidence" },
        "hype_score": { "$ref": "#/$defs/Confidence" },
        "intensity_score": { "$ref": "#/$defs/Confidence" },
        "confusion_score": { "$ref": "#/$defs/Confidence" },
        "frustration_score": { "$ref": "#/$defs/Confidence" },
        "valence": { "$ref": "#/$defs/Score" },
        "reaction_type": { "type": "string" },
        "target_type": { "type": "string" },
        "target_text": { "type": "string" },
        "event_hint": { "type": "string" },
        "confidence": { "$ref": "#/$defs/Confidence" },
        "evidence_ids": { "$ref": "#/$defs/StringArray" },
        "transcript_text": { "type": "string" },
        "transcript_confidence": { "$ref": "#/$defs/Confidence" },
        "sentiment_confidence": { "$ref": "#/$defs/Confidence" },
        "evidence_messages": {
          "type": "array",
          "items": { "$ref": "#/$defs/ChatMessage" }
        }
      }
    },
    "TranscriptState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "mode"],
      "properties": {
        "mode": { "type": "string" },
        "status": { "type": "string" },
        "session_id": { "type": "string" },
        "channel_id": { "type": "string" },
        "bucket_seconds": { "type": "number" },
        "chunk_seconds": { "type": "number" },
        "segment_count": { "type": "integer", "minimum": 0 },
        "bucket_count": { "type": "integer", "minimum": 0 },
        "error": { "type": "string" },
        "partial_count": { "type": "integer", "minimum": 0 },
        "caption": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "rolling_window_seconds": { "type": "number" },
            "asr_interval_seconds": { "type": "number" },
            "stability_passes": { "type": "integer", "minimum": 0 },
            "rolling_buffer_seconds": { "type": "number" },
            "commit_lag_seconds": { "type": "number" }
          }
        },
        "partials": {
          "type": "array",
          "items": { "$ref": "#/$defs/TranscriptUpdate" }
        },
        "segments": {
          "type": "array",
          "items": { "$ref": "#/$defs/TranscriptUpdate" }
        },
        "buckets": {
          "type": "array",
          "items": { "$ref": "#/$defs/TranscriptBucket" }
        },
        "latest_partial": {
          "anyOf": [
            { "$ref": "#/$defs/TranscriptUpdate" },
            { "type": "null" }
          ]
        },
        "latest_segment": {
          "anyOf": [
            { "$ref": "#/$defs/TranscriptUpdate" },
            { "type": "null" }
          ]
        },
        "latest_bucket": {
          "anyOf": [
            { "$ref": "#/$defs/TranscriptBucket" },
            { "type": "null" }
          ]
        }
      }
    }
  }
}
