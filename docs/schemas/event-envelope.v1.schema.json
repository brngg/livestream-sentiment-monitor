{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stream-reaction-intelligence.local/schemas/event-envelope.v1.schema.json",
  "title": "Stream Reaction Intelligence Event Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "event_schema_version",
    "source",
    "occurred_at",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "enum": [
        "chat_bucket",
        "transcript_bucket",
        "analysis_result",
        "system_metric"
      ]
    },
    "event_schema_version": {
      "const": "v1"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string"
    },
    "channel_id": {
      "type": "string"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object"
    }
  }
}
