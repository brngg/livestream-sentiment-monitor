# Copy to .env.production for the provider-neutral production compose profile.
# Values below are placeholders only. Do not commit real secrets.

COMPOSE_PROJECT_NAME=stream-reaction-prod
PUBLIC_HTTP_PORT=8080
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
REDPANDA_EXTERNAL_PORT=19092

# Local-build image tags for services that exist in this repository.
DASHBOARD_IMAGE=stream-reaction-dashboard:prod-local
SENTIMENT_ANALYZER_IMAGE=stream-reaction-sentiment-analyzer:prod-local
TRANSCRIPT_INGESTOR_IMAGE=stream-reaction-transcript-ingestor:prod-local
EVENT_GATEWAY_IMAGE=stream-reaction-event-gateway:prod-local
ANALYSIS_SERVICE_IMAGE=stream-reaction-analysis-service:prod-local

# Twitch credentials and optional IRC identity.
TWITCH_CLIENT_ID=replace-with-twitch-client-id
TWITCH_CLIENT_SECRET=replace-with-twitch-client-secret
TWITCH_APP_ACCESS_TOKEN=
TWITCH_IRC_NICK=
TWITCH_IRC_OAUTH_TOKEN=
TWITCH_CHANNEL=replace-with-demo-channel

# Container-to-container service URLs.
NLP_ANALYZER_URL=http://sentiment-analyzer:8091
TRANSCRIPT_INGESTOR_URL=http://transcript-ingestor:8092
EVENT_GATEWAY_URL=http://event-gateway:8093
ANALYSIS_SERVICE_URL=http://analysis-service:8094
KAFKA_BROKERS=redpanda:9092
EVENT_TOPIC_PREFIX=stream-intelligence
EVENT_BUS_ENABLED=true
ANALYSIS_SERVICE_REQUIRED=true

# Private live-demo controls. Public reads stay open; mutating live controls
# require Authorization: Bearer ADMIN_TOKEN by default.
ADMIN_TOKEN=replace-with-generated-admin-token
PUBLIC_START_ENABLED=false
MAX_ACTIVE_SESSIONS=1
SESSION_MAX_DURATION=20m
LIVE_SOURCE_ALLOWLIST=
DAILY_LIVE_START_LIMIT=0

# Runtime tuning.
CHAT_BUCKET_EVERY=10s
TRANSCRIPT_POLL_INTERVAL=1s
TRANSCRIPT_BUCKET_SECONDS=10
TRANSCRIPT_DEFAULT_CHUNK_SECONDS=1
NLP_ANALYZER_TIMEOUT=5s
NLP_ANALYZER_LATE_TIMEOUT=20s
TRANSCRIPT_NLP_ANALYZER_TIMEOUT=15

# Sentiment analyzer settings.
SENTIMENT_MODEL=cardiffnlp/twitter-xlm-roberta-base-sentiment-multilingual
SENTIMENT_BATCH_SIZE=16
SENTIMENT_TRACE_LIMIT=18
SENTIMENT_MAX_MESSAGES=32
SENTIMENT_MAX_TEXT_CHARS=280
SENTIMENT_DEVICE=-1
SENTIMENT_WARMUP=true
SENTIMENT_CPUS=2.0
ML_OMP_NUM_THREADS=2
ML_MKL_NUM_THREADS=2
ML_OPENBLAS_NUM_THREADS=2
ML_NUMEXPR_NUM_THREADS=2
ML_VECLIB_MAXIMUM_THREADS=2
TOKENIZERS_PARALLELISM=false

# Transcript ingestor settings. NVIDIA_API_KEY is required for hosted ASR.
TRANSCRIPT_CPUS=6.0
TRANSCRIPT_ASR_PROVIDER=nvidia_streaming
TRANSCRIPT_ASR_QUEUE_MAX_DEPTH=4
TRANSCRIPT_REPAIR_ENABLED=false
CAPTION_ROLLING_WINDOW_SECONDS=10
CAPTION_ASR_INTERVAL_SECONDS=1
NVIDIA_API_KEY=replace-with-nvidia-api-key
NVIDIA_NIM_ASR_PYTHON=python3
NVIDIA_NIM_ASR_HELPER=/app/scripts/nvidia_asr_transcribe.py
NVIDIA_NIM_ASR_STREAMING_HELPER=/app/scripts/nvidia_live_stream_asr.py
NVIDIA_NIM_ASR_SERVER=grpc.nvcf.nvidia.com:443
NVIDIA_NIM_ASR_FUNCTION_ID=replace-with-nvidia-function-id
NVIDIA_NIM_ASR_MODEL_NAME=
NVIDIA_NIM_ASR_LANGUAGE_CODE=en-US
NVIDIA_NIM_ASR_FILE_STREAMING_CHUNK=1600

# Persistent storage. Use Neon, RDS, or another managed Postgres endpoint.
DATABASE_URL=postgresql://replace-with-user:replace-with-password@replace-with-host:5432/replace-with-database?sslmode=require
DATABASE_WRITE_ENABLED=true
DATABASE_WRITE_TIMEOUT=10s
DATABASE_WRITE_QUEUE_SIZE=256
DATABASE_WRITE_MAX_RETRIES=3
DATABASE_HEALTH_FAILURE_THRESHOLD=3
CHAT_SAMPLE_LIMIT_PER_BUCKET=10
CHAT_IDENTITY_HASH_SALT=replace-with-generated-random-salt

# Event gateway and analysis boundary service settings.
EVENT_GATEWAY_ADDR=:8093
EVENT_GATEWAY_KAFKA_BROKERS=redpanda:9092
EVENT_GATEWAY_KAFKA_CLIENT_ID=stream-event-gateway
EVENT_GATEWAY_PUBLISH_TIMEOUT=5s
EVENT_GATEWAY_SHUTDOWN_TIMEOUT=5s
ANALYSIS_ADDR=:8094
ANALYSIS_ALIGNMENT_WINDOW=30s
ANALYSIS_STORAGE_TIMEOUT=2s
ANALYSIS_MAX_BUCKETS_PER_SESSION=500

# Grafana bootstrap account. Replace before exposing Grafana.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-generated-grafana-admin-password
GRAFANA_ROOT_URL=http://localhost:3000/
