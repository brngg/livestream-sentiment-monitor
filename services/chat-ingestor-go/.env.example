TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_APP_ACCESS_TOKEN=
TWITCH_IRC_NICK=
TWITCH_IRC_OAUTH_TOKEN=
NLP_ANALYZER_URL=http://127.0.0.1:8091
NLP_ANALYZER_TIMEOUT=5s
FRONTEND_DIR=../../apps/dashboard

# Optional Neon/Postgres persistence. Leave DATABASE_URL empty to use the
# in-memory/no-op store during local development.
DATABASE_URL=
DATABASE_WRITE_ENABLED=true
DATABASE_WRITE_TIMEOUT=2s
CHAT_SAMPLE_LIMIT_PER_BUCKET=10
CHAT_IDENTITY_HASH_SALT=
